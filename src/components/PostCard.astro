---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  url: string;
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  heroImage?: ImageMetadata;
  heroAlt?: string;
  featured?: boolean;
}

const { url, title, date, description, tags = [], heroImage, heroAlt, featured = false } =
  Astro.props;
---

<article class:list={['card', { 'card--featured': featured }]}>
  {
    heroImage && (
      <a class="card-media" href={url} tabindex="-1" aria-hidden="true">
        <Image
          src={heroImage}
          alt={heroAlt ?? ''}
          widths={featured ? [480, 900, 1200] : [400, 800]}
          sizes={featured ? '(max-width: 48rem) 100vw, 60rem' : '(max-width: 48rem) 100vw, 44rem'}
        />
      </a>
    )
  }
  <div class="card-body">
    <p class="card-meta">
      <FormattedDate date={date} />
      {featured && <span class="card-flag">Latest</span>}
    </p>
    <h2 class="card-title"><a href={url}>{title}</a></h2>
    {description && <p class="card-desc">{description}</p>}
    {
      tags.length > 0 && (
        <ul class="card-tags">
          {tags.slice(0, 4).map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .card {
    padding-block: 2.25rem;
    border-bottom: 1px solid var(--line);
  }
  .card-media {
    display: block;
    margin-bottom: 1.5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }
  .card-media :global(img) {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
    transition: transform 0.5s var(--ease);
  }
  .card:hover .card-media :global(img) {
    transform: scale(1.02);
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .card-flag {
    color: var(--accent-deep);
    font-weight: 600;
  }
  .card-title {
    margin: 0;
    font-size: var(--h3);
    letter-spacing: -0.015em;
  }
  .card-title a {
    color: var(--ink);
    text-decoration: none;
  }
  .card-title a:hover {
    color: var(--accent-deep);
  }
  .card-desc {
    margin: 0.55rem 0 0;
    color: var(--ink-2);
    max-width: var(--measure);
  }
  .card-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 1rem 0 0;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
  }
  .card-tags li {
    color: var(--muted);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }

  /* featured: larger title */
  .card--featured .card-title {
    font-size: var(--h2);
  }
  .card--featured .card-desc {
    font-size: var(--text-lg);
    line-height: 1.55;
  }
</style>
