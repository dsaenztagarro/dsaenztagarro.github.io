---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  url: string;
  title: string;
  date: Date;
  description?: string;
  heroImage?: ImageMetadata;
  heroAlt?: string;
}

const { url, title, date, description, heroImage, heroAlt } = Astro.props;
---

<article class="post-card">
  <a class="post-card-link" href={url}>
    {
      heroImage && (
        <Image
          class="post-card-image"
          src={heroImage}
          alt={heroAlt ?? ''}
          widths={[400, 800]}
          sizes="(max-width: 48rem) 100vw, 48rem"
        />
      )
    }
    <h2 class="post-card-title">{title}</h2>
    <p class="post-card-meta"><FormattedDate date={date} /></p>
    {description && <p class="post-card-desc">{description}</p>}
  </a>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--color-border);
    padding-block: 1.75rem;
  }
  .post-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .post-card-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    margin-bottom: 1rem;
  }
  .post-card-title {
    margin: 0 0 0.25rem;
    font-size: 1.35rem;
  }
  .post-card-meta {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .post-card-desc {
    margin: 0;
    color: var(--color-muted);
  }
  .post-card-link:hover .post-card-title {
    color: var(--color-accent);
  }
</style>
