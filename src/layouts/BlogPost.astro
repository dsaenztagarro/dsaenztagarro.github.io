---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: ImageMetadata;
  heroAlt?: string;
  heroInArticle?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  heroImage,
  heroAlt,
  heroInArticle = true,
  ogImage,
} = Astro.props;
const slugifyTag = (t: string) => t.replace(/\s+/g, '-').toLowerCase();
---

<BaseLayout title={title} description={description} image={ogImage} type="article">
  <article class="post">
    <header class="container post-header">
      <a class="back rise" href="/">← Writing</a>
      <h1 class="post-title rise" style="animation-delay: 60ms">{title}</h1>
      {
        description && (
          <p class="post-standfirst rise" style="animation-delay: 120ms">
            {description}
          </p>
        )
      }
      <div class="post-byline rise" style="animation-delay: 180ms">
        <FormattedDate date={date} />
        {updatedDate && <span>· updated <FormattedDate date={updatedDate} /></span>}
        {
          tags.length > 0 && (
            <ul class="post-tags">
              {tags.map((tag) => (
                <li>
                  <a href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    {
      heroImage && heroInArticle && (
        <figure class="post-hero rise" style="animation-delay: 240ms">
          <Image
            src={heroImage}
            alt={heroAlt ?? ''}
            widths={[480, 960, 1440]}
            sizes="(max-width: 62rem) 100vw, 60rem"
          />
        </figure>
      )
    }

    <div class="container">
      <div class="prose">
        <slot />
      </div>
      <footer class="post-foot">
        <a class="back" href="/">← Back to writing</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: clamp(2rem, 5vw, 3.5rem);
  }
  .back {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
  }
  .back:hover {
    color: var(--accent-deep);
  }
  .post-header {
    margin-bottom: 2.5rem;
  }
  .post-title {
    margin: 1rem 0 0;
    font-size: var(--h1);
    letter-spacing: -0.02em;
  }
  .post-standfirst {
    margin: 1.1rem 0 0;
    font-size: var(--lede);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 52ch;
  }
  .post-byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    margin-top: 1.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-tags a {
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line-strong);
  }
  .post-tags a:hover {
    color: var(--accent-deep);
    border-color: var(--accent);
  }

  /* hero spans a wider editorial column */
  .post-hero {
    max-width: var(--wide);
    margin: 0 auto 3rem;
    padding-inline: clamp(1.25rem, 5vw, 2rem);
  }
  .post-hero :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  /* --- reading column --- */
  .prose {
    max-width: var(--measure);
    margin-inline: auto;
    color: var(--n-800);
    font-size: var(--text-prose);
  }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote) {
    margin-block: 1.2rem;
  }
  /* lead paragraph gets a touch more presence */
  .prose :global(> p:first-of-type) {
    font-size: 1.15rem;
    color: var(--ink);
  }
  .prose :global(h2) {
    margin-top: 2.75rem;
    margin-bottom: 0.5rem;
    font-size: var(--h2);
  }
  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.4rem;
    font-size: var(--h3);
  }
  .prose :global(strong) {
    font-weight: 600;
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.3rem;
  }
  .prose :global(li) {
    margin-block: 0.4rem;
  }
  .prose :global(li::marker) {
    color: var(--accent);
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding: 0.2rem 0 0.2rem 1.25rem;
    margin-inline: 0;
    color: var(--ink-2);
    font-style: italic;
  }
  .prose :global(a) {
    font-weight: 500;
  }

  /* figures + captions */
  .prose :global(figure) {
    margin: 2.5rem 0;
  }
  .prose :global(figure img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }
  .prose :global(figcaption) {
    margin-top: 0.7rem;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--muted);
    text-align: center;
  }

  /* tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    margin-block: 1.5rem;
  }
  .prose :global(thead th) {
    text-align: left;
    border-bottom: 2px solid var(--line-strong);
    padding: 0.6rem 0.8rem;
    font-weight: 600;
  }
  .prose :global(td) {
    border-bottom: 1px solid var(--line);
    padding: 0.55rem 0.8rem;
    vertical-align: top;
  }

  /* Expressive Code blocks: lift onto the page with a soft frame */
  .prose :global(.expressive-code) {
    margin-block: 1.75rem;
  }
  .prose :global(.expressive-code .frame) {
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .post-foot {
    max-width: var(--measure);
    margin: 3.5rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
</style>
